# Build artifacts
/target/
**/*.rs.bk
Cargo.lock.bak

# Editor
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Repo-specific lines preserved from prior .gitignore:
Cargo.lock
